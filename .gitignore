## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons

# Build outputs (recursive)
**/bin/
**/obj/

# Visual Studio
.vs/
*.user
*.suo
*.cache
*.userosscache
*.sln.docstates

# Debug symbols
*.pdb

# Executables & libraries
*.exe
*.dll
*.dll.config
*.xml
*.deps.json
*.runtimeconfig.json

# Database & logs
*.db
logs/
*.log

# NuGet
packages/
[Nn]uGet/

# Test results
TestResults/

# Node modules (eğer Blazor Client-side kullanıyorsan)
node_modules/

# Local config dosyaları (KESİNLİKLE ignore!)
appsettings.Development.json
appsettings.Local.json
secrets.json

# wwwroot/ TAMAMEN IGNORE EDİLMEZ!
# Ama otomatik üretilen alt klasörler varsa:
# wwwroot/lib/

# ⚠️ DİKKAT: Aşağıdaki satırı YAZMA:
# wwwroot/
# → Çünkü Blazor dosyaların (index.html, app.css, vs.) git'e GİRMELİ!
